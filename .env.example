# 文心一言 API Key（新版，直接填 API Key）
QIANFAN_API_KEY=your_qianfan_api_key_here

# Tavily 搜索 API Key
TAVILY_API_KEY=your_tavily_api_key_here

# 阿里百炼 API Key（可选，使用通义千问模型时填写）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# LLM 选择：格式为 provider/model，provider 可选 qianfan 或 bailian
# qianfan 示例：qianfan/ernie-speed-pro-128k、qianfan/ernie-4.0-8k
# bailian 示例：bailian/qwen-plus、bailian/qwen-turbo、bailian/qwen-max
LLM=qianfan/ernie-speed-pro-128k
