# 文心一言 API Key（新版，直接填 API Key）
QIANFAN_API_KEY=your_qianfan_api_key_here

# Tavily 搜索 API Key
TAVILY_API_KEY=your_tavily_api_key_here

# 阿里百炼 API Key（可选，使用通义千问模型时填写）
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# LLM 选择：格式为 provider/model，provider 可选 qianfan 或 bailian
# qianfan 示例：qianfan/ernie-speed-pro-128k、qianfan/ernie-4.0-8k
# bailian 示例：bailian/qwen-plus、bailian/qwen-turbo、bailian/qwen-max
LLM=bailian/qwen3.5-flash

# LLM 备用模型（可选）：额度不足时依次切换，逗号分隔，格式同 LLM
# 示例：bailian/qwen-turbo,qianfan/ernie-speed-pro-128k
# LLM_FALLBACK=bailian/qwen-turbo,qianfan/ernie-speed-pro-128k

# 调试日志开关：true 输出详细日志（tool 参数、模型切换、报错堆栈），false 只输出 WARNING+
DEBUG=false

# 流式输出超时秒数（可选，默认 120）：模型生成慢时适当调大
# STREAM_TIMEOUT=120

# 访问统计 + 留言板（可选）：用 GitHub Gist 持久化访问数和查询数
# 1. 在 github.com/gist 新建 Secret Gist，文件名 rag_agent_stats.json
#    内容：{"visits": 0, "queries": 0, "feedback": []}
# 2. GitHub Settings → Developer settings → Personal access tokens → 创建有 gist 权限的 token
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# GIST_ID=your_gist_hash_id

# Qdrant Cloud 持久化向量库（可选）
# 配置后自动使用 Qdrant Cloud，未配置则降级到本地 ChromaDB
# 1. 注册 cloud.qdrant.io，创建 Free tier cluster（1GB）
# 2. 填入 Cluster URL 和 API Key
# QDRANT_URL=https://xxxx.us-east-1-0.aws.cloud.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key_here
